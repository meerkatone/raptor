#!/usr/bin/env python3
"""Project management CLI — wraps core.project.cli.

Usage: raptor-project-manager <subcommand> [args]

Called by:
  - bin/raptor project <subcommand>
  - /project skill in Claude Code
"""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from core.project.cli import main

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        sys.exit(130)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)
