#!/usr/bin/env python3
"""
raptor-run-sandboxed — execute a binary inside the full sandbox.

Usage: raptor-run-sandboxed <binary> [args...]

Applies all available isolation:
- Network blocked (unshare --user --net)
- Filesystem write restriction (Landlock)
- Resource limits (memory, file size, CPU time)

Falls back gracefully when features are unavailable.

Environment:
- OUTPUT_DIR (required): writable directory for the sandboxed child. Must
  be set explicitly — there is no safe default (using /tmp would let
  the child write anywhere in /tmp, which defeats isolation). Set to a
  dedicated per-invocation directory.

stdout/stderr pass through directly so the caller (including LLM agents)
sees the child's output. Sandbox diagnostics and structured errors are
printed to stderr prefixed `[sandbox] ` after the child exits.

Exit codes:
- Child's returncode on successful invocation
- 1 on misuse (missing args, missing OUTPUT_DIR)
- 2 on sandbox invocation failure (unshare, kernel, etc.)
"""

import logging
import os
import sys

# RAPTOR imports
raptor_dir = str(__import__("pathlib").Path(__file__).resolve().parents[1])  # libexec -> raptor
# ─── trust-marker check (do not import; inline by design) ───
if not (os.environ.get("CLAUDECODE")
        or os.environ.get("_RAPTOR_TRUSTED")):
    sys.stderr.write(
        f"{sys.argv[0]}: internal dispatch script.\n"
        "  Run via 'bin/raptor' instead.\n"
        "  Tests / power users: set _RAPTOR_TRUSTED=1 to bypass.\n"
    )
    sys.exit(2)
# ─── end trust-marker check ─────────────────────────────────

sys.path.insert(0, raptor_dir)


def _die(msg: str, code: int = 1) -> None:
    print(f"[sandbox] ERROR: {msg}", file=sys.stderr)
    sys.exit(code)


if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
    usage = (
        "Usage: raptor-run-sandboxed <binary> [args...]\n"
        "Required env: OUTPUT_DIR (writable dir for the sandboxed child).\n"
        "See libexec/raptor-run-sandboxed docstring for details."
    )
    print(usage, file=sys.stderr)
    sys.exit(0 if len(sys.argv) >= 2 else 1)

cmd = sys.argv[1:]

# OUTPUT_DIR must be explicit — the former fallback to /tmp gave callers
# the illusion of isolation when they forgot to set it (the child could
# still write anywhere in shared /tmp).
output_dir = os.environ.get("OUTPUT_DIR")
if not output_dir:
    _die("OUTPUT_DIR env var must be set to a writable dir for the sandboxed child")

# basicConfig sets the root logger at WARNING so unrelated modules stay
# quiet, then we raise ONLY core.sandbox to INFO so its enforcement
# diagnostics (network blocked, write denied, etc.) reach stderr. Without
# this scoping, every RAPTOR module's INFO logs would flood the child's
# stderr — and this script is what the LLM calls as a subprocess.
logging.basicConfig(level=logging.WARNING, format="%(message)s", stream=sys.stderr)
logging.getLogger("core.sandbox").setLevel(logging.INFO)

from core.sandbox import sandbox

try:
    with sandbox(block_network=True,
                 target=os.getcwd(),
                 output=output_dir) as run:
        # Run with captured stderr so _check_blocked can inspect it,
        # but print it through so the caller sees it too.
        result = run(cmd, capture_output=True, text=True)

        # Pass through child output
        if result.stdout:
            sys.stdout.write(result.stdout)
            sys.stdout.flush()
        if result.stderr:
            sys.stderr.write(result.stderr)
            sys.stderr.flush()

        # Surface sandbox diagnostics for the caller
        info = result.sandbox_info
        if info.get("crashed"):
            print(f"[sandbox] {info.get('evidence', 'Process crashed')}", file=sys.stderr)
        elif info.get("resource_exceeded"):
            print(f"[sandbox] {info.get('evidence', 'Resource limit exceeded')}", file=sys.stderr)
        if info.get("blocked"):
            for item in info["blocked"]:
                print(f"[sandbox] {item}", file=sys.stderr)
except (OSError, RuntimeError, ValueError) as e:
    _die(f"sandbox invocation failed: {e.__class__.__name__}: {e}", code=2)

sys.exit(result.returncode)
